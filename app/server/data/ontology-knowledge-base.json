  "description": "面向科研项目立项、中期和结题评审的本体知识库，包含概念、证据模式和规则画像，用于驱动评审项规则校验。",
  "concepts": [
    {
      "id": "innovation",
      "label": "创新性",
      "aliases": ["创新", "原创", "差异化"],
      "description": "用于判断项目技术路线是否具备创新点和差异化优势。"
    },
    {
      "id": "novelty",
      "label": "技术新颖性",
      "aliases": ["新颖", "首创", "创新亮点"],
      "description": "强调方案在模型设计、方法组合或应用路径上的新意。"
    },
    {
      "id": "advancement",
      "label": "技术先进性",
      "aliases": ["先进性", "领先性", "效果优势"],
      "description": "强调方案相较现有公开方法的性能或能力优势。"
    },
    {
      "id": "feasibility",
      "label": "可行性",
      "aliases": ["可行", "落地", "实施条件"],
      "description": "用于判断项目实施条件是否齐备。"
    },
    {
      "id": "tech-maturity",
      "label": "技术成熟度",
      "aliases": ["成熟度", "研发基础", "技术准备"],
